# Environment Variables — copy this file to .env and fill in the values
# Never commit .env to version control

# Google Apps Script Web App URL (required for contact form)
# Deploy your Apps Script as a Web App (Execute as: Me, Access: Anyone)
# and paste the URL below.
# See google-apps-script/DEPLOYMENT.md for full setup instructions.
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
